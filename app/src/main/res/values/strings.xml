    <string name="shizuku_back">Back</string>

    <!-- Setup screen — checklist + troubleshooting (Brick G). -->
    <string name="shizuku_setup_steps_section">Setup steps</string>
    <string name="shizuku_setup_step_install">Install Shizuku</string>
    <string name="shizuku_setup_step_install_subtitle">Get the Shizuku Manager app from the Play Store or GitHub.</string>
    <string name="shizuku_setup_step_start">Start Shizuku</string>
    <string name="shizuku_setup_step_start_subtitle">Pair Shizuku once via wireless debugging. Re-launch after every reboot.</string>
    <string name="shizuku_setup_step_grant">Grant Mapo permission</string>
    <string name="shizuku_setup_step_grant_subtitle">Approve Mapo\'s request inside Shizuku.</string>
    <string name="shizuku_setup_step_done">Done</string>
    <string name="shizuku_setup_step_pending">Pending</string>
    <string name="shizuku_setup_step_current">Do this next</string>
    <string name="shizuku_setup_troubleshooting_section">Troubleshooting</string>
    <string name="shizuku_setup_troubleshooting_state_changes">Shizuku state takes a moment to refresh after install / pair / grant — pull down to refresh or re-open this screen if it seems stuck.</string>
    <string name="shizuku_setup_troubleshooting_reboot">Shizuku needs to be re-started after every device reboot (wireless-debugging install) — Mapo will pick it up automatically once running.</string>
    <string name="shizuku_setup_troubleshooting_digital">If you only use digital remap (gamepad button → keyboard), Shizuku is optional. Mapo will work without it.</string>

    <!-- Shizuku-required dialog (Brick G). Shown on first analog-mode pick while
         Shizuku isn\'t ready. State-aware body copy. -->
    <string name="shizuku_required_dialog_title">Analog modes need Shizuku</string>
    <string name="shizuku_required_dialog_intro">Mapo uses Shizuku to read gamepad sticks and triggers directly. Without Shizuku, analog modes (Trigger Soft Pull, Joystick → mouse, etc.) can\'t fire.</string>
    <string name="shizuku_required_dialog_state_not_installed">You don\'t have Shizuku installed yet. Setup walks you through it — Play Store or GitHub.</string>
    <string name="shizuku_required_dialog_state_installed_not_running">Shizuku is installed but not running. Setup will help you start it (one-time wireless-debugging pair, then re-launch after each boot).</string>
    <string name="shizuku_required_dialog_state_running_not_granted">Shizuku is running. Mapo just needs your permission — Setup grants it in one tap.</string>
    <string name="shizuku_required_dialog_state_granted">Shizuku is ready — analog modes should just work.</string>
    <string name="shizuku_required_dialog_outro">Your binding will save now and activate automatically as soon as Shizuku is set up.</string>
    <string name="shizuku_required_dialog_cta_set_up">Set up Shizuku</string>

    <!-- Shizuku health notification (Brick G). Posted when an analog mode is in
         scope for the foreground app but Shizuku isn\'t ready. -->
    <string name="shizuku_health_channel_name">Shizuku health</string>
    <string name="shizuku_health_channel_description">Persistent reminder when an analog mode is configured for the foreground app but Shizuku isn\'t connected.</string>
    <string name="shizuku_health_notification_title">Analog input paused</string>
    <string name="shizuku_health_notification_text">Shizuku isn\'t connected. Tap to set it up.</string>

    <!-- Remap Controls inline banner (Brick G follow-up). Shown when any analog
         mode is configured in the current controller config AND Shizuku is not
         ready — surfaces the gap for users who applied analog modes before
         Shizuku was set up, or whose Shizuku connection later broke. -->
    <string name="remap_shizuku_unavailable_banner">Analog modes won\'t fire — Shizuku isn\'t connected.</string>
