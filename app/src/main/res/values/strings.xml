    <!-- Shizuku Setup screen. -->
    <string name="shizuku_screen_title">Shizuku</string>
    <string name="shizuku_intro">Shizuku is required for Mapo\'s analog input modes (stick → mouse, soft trigger pulls, etc.). Digital remap (gamepad button → keyboard) works without Shizuku.</string>
    <string name="shizuku_state_not_installed">Shizuku is not installed.</string>
    <string name="shizuku_state_installed_not_running">Shizuku is installed, but the service is not running.</string>
    <string name="shizuku_state_running_not_granted">Shizuku is running. Mapo needs your permission.</string>
    <string name="shizuku_state_granted">Shizuku is ready.</string>
    <string name="shizuku_install_button">Install Shizuku</string>
    <string name="shizuku_open_app_button">Open Shizuku app</string>
