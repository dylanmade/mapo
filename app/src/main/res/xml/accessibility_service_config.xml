<?xml version="1.0" encoding="utf-8"?>
<!--
    canRetrieveWindowContent + flagRetrieveInteractiveWindows are required so the service
    can call getWindowsOnAllDisplays() and read the foreground app package for the primary
    display on activity resume — without these, dual-display devices (AYN Thor) fail to
    auto-switch profiles when Mapo opens on the bottom screen with a game already running
    on the primary screen.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagRequestFilterKeyEvents|flagRetrieveInteractiveWindows"
    android:canPerformGestures="true"
    android:canRequestFilterKeyEvents="true"
    android:canRetrieveWindowContent="true"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100"
    android:settingsActivity="com.mapo.MainActivity" />
